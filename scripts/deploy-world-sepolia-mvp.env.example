# Copy to .env.deploy.world and fill values
# Usage:
#   cp scripts/deploy-world-sepolia-mvp.env.example .env.deploy.world
#   bash scripts/deploy-world-sepolia-mvp.sh .env.deploy.world

# Optional. Default is public endpoint.
# Better: use your own RPC (Alchemy/Infura/QuickNode) for reliability.
WORLD_SEPOLIA_RPC_URL=https://worldchain-sepolia.g.alchemy.com/public

# Required. Deployer EOA private key.
# Where to get:
# - from your wallet export (burner/test wallet only)
# - or a dedicated test wallet from your key manager
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Required. Wallet that will own YieldVault and receive minted test USDC.
# Where to get:
# - your wallet address in World App / MetaMask / Rabby
OWNER=0xYOUR_WALLET_ADDRESS

# Optional. CRE forwarder allowed to trigger rebalances.
# For MVP, set to OWNER.
CRE_FORWARDER=0xYOUR_WALLET_ADDRESS

# Optional. Mint amount in token base units (6 decimals for TestUSDC).
# 100000000000 = 100,000 tUSDC
MINT_AMOUNT_UNITS=100000000000

# Optional. Dummy router override for vault-only MVP (no CCIP flows yet).
HOME_ROUTER_OVERRIDE=0x000000000000000000000000000000000000dEaD

# Optional. Initial logical chain label stored in vault.
INITIAL_YIELD_CHAIN=worldLocal

# Optional safety check. World Sepolia is chain ID 4801.
CHAIN_ID_EXPECTED=4801
