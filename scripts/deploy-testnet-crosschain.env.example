# Real cross-chain testnet deployment (Ethereum Sepolia home).
#
# Usage:
#   cp scripts/deploy-testnet-crosschain.env.example .env.deploy.testnet.crosschain
#   # edit .env.deploy.testnet.crosschain
#   bash scripts/deploy-testnet-crosschain.sh .env.deploy.testnet.crosschain
#
# IMPORTANT:
# - Use the SAME EOA private key on all three chains (Sepolia, Arbitrum Sepolia, OP Sepolia).
# - Fund that EOA with native gas on all three chains.
# - Fund the vault with native ETH for CCIP fees via VAULT_NATIVE_FUND_WEI.

# Required signer + ownership
DEPLOYER_PRIVATE_KEY=0xYOUR_EOA_PRIVATE_KEY
OWNER=0xYOUR_EOA_ADDRESS
CRE_FORWARDER=0xYOUR_EOA_ADDRESS

# RPCs
ETH_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
ARBITRUM_SEPOLIA_RPC_URL=https://arbitrum-sepolia-rpc.publicnode.com
OPTIMISM_SEPOLIA_RPC_URL=https://sepolia.optimism.io

# Home chain config (Ethereum Sepolia)
HOME_CHAIN_MODE=eth
HOME_SELECTOR=16015286601757825753
HOME_ROUTER=0x0BF3dE8c5D3e8A2B34D2BEeB17ABfCeBaf363A59
HOME_USDC=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
INITIAL_YIELD_CHAIN=arbitrumSepolia

# Arbitrum Sepolia destination
ARBITRUM_SELECTOR=3478487238524512106
ARBITRUM_ROUTER=0x2a9C5afB0d0e4BAb2BCdaE109EC4b0c4Be15a165
ARBITRUM_POOL=0xBfC91D59fdAA134A4ED45f7B584cAf96D7792Eff
ARBITRUM_USDC=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d
ARBITRUM_A_TOKEN=0x460b97BD498E1157530AEb3086301d5225b91216
ARBITRUM_DATA_PROVIDER=0x12373B5085e3b42D42C1D4ABF3B3Cf4Df0E0Fa01

# OP Sepolia destination
OPTIMISM_SELECTOR=5224473277236331295
OPTIMISM_ROUTER=0x114A20A10b43D4115e5aeef7345a1A71d2a60C57
OPTIMISM_POOL=0xb50201558B00496A145fE76f7424749556E326D8
OPTIMISM_USDC=0x5fd84259d66Cd46123540766Be93DFE6D43130D7
OPTIMISM_A_TOKEN=0xa818F1B57c201E092C4A2017A91815034326Efd1
OPTIMISM_DATA_PROVIDER=0x501B4c19dd9C2e06E94dA7b6D5Ed4ddA013EC741

# Optional: fund vault with ETH for CCIP fees right after deployment
# 0.01 ETH = 10000000000000000 wei
VAULT_NATIVE_FUND_WEI=10000000000000000

# Optional: fund destination receivers with native gas to pay CCIP return-message fees
# Recommended non-zero for real rebalance/withdraw flows.
ARBITRUM_RECEIVER_NATIVE_FUND_WEI=1000000000000000
OPTIMISM_RECEIVER_NATIVE_FUND_WEI=1000000000000000

# Optional output path
TESTNET_CROSSCHAIN_REGISTRY=deployments/addresses.testnet.crosschain.json
