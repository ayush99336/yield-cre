# Omni-Yield Environment Template
# Copy to `.env` and fill values.

# ==================================
# 1) Runtime mode
# ==================================
# testnet_hybrid | mainnet_live
EXECUTION_MODE=testnet_hybrid
NEXT_PUBLIC_EXECUTION_MODE=testnet_hybrid

# ==================================
# 2) Database (required)
# ==================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/omni_yield?schema=public

# ==================================
# 3) World ID / Mini App (required for phone flow)
# ==================================
WORLD_ID_DEV_BYPASS=false
NEXT_PUBLIC_WORLD_ID_DEV_BYPASS=false

WORLD_APP_ID=app_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_WORLD_APP_ID=app_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

WORLD_RP_ID=rp_xxxxxxxxxxxxxxxx
NEXT_PUBLIC_WORLD_RP_ID=rp_xxxxxxxxxxxxxxxx

WORLD_ID_ACTION=omni-yield-access
NEXT_PUBLIC_WORLD_ID_ACTION=omni-yield-access

WORLD_ID_ENVIRONMENT=production
NEXT_PUBLIC_WORLD_ID_ENVIRONMENT=production
WORLD_ID_REQUEST_TTL_SECONDS=300

# Secret: from World Developer Portal (Keys)
WORLD_ID_SIGNER_PRIVATE_KEY=0xYOUR_WORLD_ID_SIGNER_PRIVATE_KEY

# Optional
NEXT_PUBLIC_WORLD_CLIENT_ID=
NEXT_PUBLIC_APP_NAME=Omni-Yield
NEXT_PUBLIC_WC_PROJECT_ID=
NEXT_PUBLIC_DEV_WALLET_ADDRESS=0x000000000000000000000000000000000000dEaD

# ==================================
# 4) RPCs
# ==================================
WORLD_SEPOLIA_RPC_URL=https://worldchain-sepolia.g.alchemy.com/public
NEXT_PUBLIC_WORLD_SEPOLIA_RPC_URL=https://worldchain-sepolia.g.alchemy.com/public
WORLD_MAINNET_RPC_URL=https://worldchain-mainnet.g.alchemy.com/public
NEXT_PUBLIC_MAINNET_WORLD_RPC_URL=https://worldchain-mainnet.g.alchemy.com/public

POLYGON_AMOY_RPC_URL=https://polygon-amoy-bor-rpc.publicnode.com
ARBITRUM_SEPOLIA_RPC_URL=https://arbitrum-sepolia-rpc.publicnode.com
ETH_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# ==================================
# 5) Home vault/token (current deployment)
# ==================================
HOME_CHAIN_MODE=world
HOME_ROUTER_OVERRIDE=0x000000000000000000000000000000000000dEaD

OWNER=0x0000000000000000000000000000000000000000
CRE_FORWARDER=0x0000000000000000000000000000000000000000

HOME_USDC=0x0000000000000000000000000000000000000000
HOME_VAULT_ADDRESS=0x0000000000000000000000000000000000000000

NEXT_PUBLIC_HOME_USDC_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_HOME_VAULT_ADDRESS=0x0000000000000000000000000000000000000000

# ==================================
# 6) Testnet hybrid aliases (used by new runtime loader)
# Keep these equal to home values unless you have separate testnet config.
# ==================================
TESTNET_HOME_USDC=0x0000000000000000000000000000000000000000
TESTNET_HOME_VAULT_ADDRESS=0x0000000000000000000000000000000000000000
TESTNET_HOME_CHAIN_MODE=world
TESTNET_HOME_RPC_URL=https://worldchain-sepolia.g.alchemy.com/public
TESTNET_WORLD_RPC_URL=https://worldchain-sepolia.g.alchemy.com/public

NEXT_PUBLIC_TESTNET_HOME_USDC_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_TESTNET_HOME_VAULT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_TESTNET_HOME_CHAIN_MODE=world
NEXT_PUBLIC_TESTNET_HOME_RPC_URL=https://worldchain-sepolia.g.alchemy.com/public
NEXT_PUBLIC_TESTNET_WORLD_RPC_URL=https://worldchain-sepolia.g.alchemy.com/public

# Optional testnet destination APR reads (used when no registry file is present)
TESTNET_ARBITRUM_SEPOLIA_RPC_URL=https://arbitrum-sepolia-rpc.publicnode.com
TESTNET_ARBITRUM_SEPOLIA_USDC=
TESTNET_ARBITRUM_SEPOLIA_DATA_PROVIDER=
TESTNET_ARBITRUM_SEPOLIA_ENABLED=true

TESTNET_OPTIMISM_SEPOLIA_RPC_URL=https://sepolia.optimism.io
TESTNET_OPTIMISM_SEPOLIA_USDC=
TESTNET_OPTIMISM_SEPOLIA_DATA_PROVIDER=
TESTNET_OPTIMISM_SEPOLIA_ENABLED=true

TESTNET_REBALANCE_THRESHOLD_BPS=50
TESTNET_COOLDOWN_SECONDS=1800
TESTNET_REBALANCE_SIMULATION=true

# ==================================
# 7) Mainnet live / shadow mode (fill only when using mainnet_live)
# ==================================
MAINNET_HOME_USDC=
MAINNET_HOME_VAULT_ADDRESS=
MAINNET_WORLD_RPC_URL=https://worldchain-mainnet.g.alchemy.com/public

NEXT_PUBLIC_MAINNET_HOME_USDC_ADDRESS=
NEXT_PUBLIC_MAINNET_HOME_VAULT_ADDRESS=
NEXT_PUBLIC_MAINNET_WORLD_RPC_URL=https://worldchain-mainnet.g.alchemy.com/public

MAINNET_MAX_DEPOSIT_UNITS=5000000
MAINNET_DEPOSITS_PAUSED=false

# ==================================
# 8) Admin APIs (required for testnet_hybrid demo)
# ==================================
ADMIN_API_KEY=replace_with_random_string
# Use either generic or testnet-specific private key
ADMIN_REBALANCE_PRIVATE_KEY=
TESTNET_ADMIN_REBALANCE_PRIVATE_KEY=
MAINNET_ADMIN_REBALANCE_PRIVATE_KEY=

# ==================================
# 9) Registry + CRE
# ==================================
TESTNET_ADDRESS_REGISTRY_PATH=deployments/addresses.testnet.crosschain.json
MAINNET_ADDRESS_REGISTRY_PATH=deployments/addresses.mainnet.json

REBALANCE_THRESHOLD_BPS=50
COOLDOWN_SECONDS=1800
CRE_ETH_PRIVATE_KEY=
CRE_TARGET=staging-settings
CRE_SCHEDULE="*/10 * * * *"
CRE_HOME_CHAIN_NAME=ethereum-testnet-sepolia
CRE_HOME_VAULT_WRITE_GAS_LIMIT=500000
CRE_CURRENT_YIELD_CHAIN_FALLBACK=
CRE_WRITE_ENABLED=false
